@page "/resolver/{QuestaoId}"
@using FeedQuestoes.Client.Modelos
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>Desafio | Base Coletiva</PageTitle>

<style>
    html, body { margin: 0; padding: 0; height: 100vh; overflow: hidden; background-color: #f7f9fc; }
    
    .tela-app { display: flex; flex-direction: column; height: 100vh; font-family: 'Segoe UI', system-ui, sans-serif; }
    
    .topo-app { flex-shrink: 0; background: #fff; padding: 15px 20px; border-bottom: 2px solid #e5e7eb; z-index: 10; display: flex; justify-content: space-between; align-items: center; }
    
    .area-split { flex-grow: 1; display: flex; flex-direction: column; overflow: hidden; }
    
    .area-enunciado { 
        flex: 0 1 auto; 
        max-height: 50%; 
        overflow-y: auto; 
        padding: 20px; 
        background: #ffffff; 
        border-bottom: 3px solid #e5e7eb; 
        box-shadow: 0 4px 10px rgba(0,0,0,0.03); 
        z-index: 2;
    }
    
    .area-alternativas { 
        flex: 1; 
        overflow-y: auto; 
        padding: 20px; 
        padding-bottom: 100px; 
        background-color: #f7f9fc;
    }

    .area-enunciado::-webkit-scrollbar, .area-alternativas::-webkit-scrollbar { width: 4px; }
    .area-enunciado::-webkit-scrollbar-thumb, .area-alternativas::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 10px; }

    .alt-opcao { border: 2px solid #e5e7eb; border-radius: 20px; padding: 16px; display: flex; align-items: flex-start; gap: 15px; transition: all 0.2s; background: #ffffff; box-shadow: 0 4px 0 #e5e7eb; margin-bottom: 16px; cursor: pointer; }
    .alt-opcao.selecionada { border-color: #1cb0f6; background-color: #ddf4ff; box-shadow: 0 4px 0 #1899d6; }
    .alt-opcao.selecionada .num-bolinha { background: #1cb0f6; color: white; border-color: #1cb0f6; }
    .alt-opcao.correta-revelada { border-color: #58cc02; background-color: #ddf4c5; box-shadow: 0 4px 0 #58a700; }
    .alt-opcao.correta-revelada .num-bolinha { background: #58cc02; color: white; border-color: #58cc02; }
    .alt-opcao.errada-revelada { border-color: #ff4b4b; background-color: #ffdfe0; box-shadow: 0 4px 0 #ea2b2b; opacity: 0.8; }
    .alt-opcao.errada-revelada .num-bolinha { background: #ff4b4b; color: white; border-color: #ff4b4b; }
    .alt-opcao.desativada { cursor: default; pointer-events: none; }
    
    .num-bolinha { width: 32px; height: 32px; border-radius: 50%; border: 2px solid #e5e7eb; display: flex; align-items: center; justify-content: center; background: #f9fafb; font-weight: bold; color: #afafaf; flex-shrink: 0; transition: all 0.2s; margin-top: 2px; }
    
    .texto-alternativa { font-size: 0.95rem; font-weight: 600; color: #4b4b4b; line-height: 1.4; word-break: break-word; }

.barra-acao-inferior { 
        position: fixed; 
        bottom: 0; 
        left: 0; 
        right: 0; 
        background: rgba(255, 255, 255, 0.95); 
        backdrop-filter: blur(10px); 
        padding: 20px; 
        /* O mesmo cálculo de respiro blindado */
        padding-bottom: calc(30px + env(safe-area-inset-bottom)); 
        border-top: 2px solid #e5e7eb; 
        z-index: 1000; 
    }
    .barra-acao-inner { max-width: 600px; margin: 0 auto; display: flex; gap: 10px; }
    
    .btn-jogavel { font-weight: 800; border-radius: 16px; border: none; padding: 14px; text-transform: uppercase; transition: all 0.1s; cursor: pointer; text-align: center; width: 100%; font-size: 1.05rem; }
    .btn-jogavel:active:not(:disabled) { transform: translateY(4px); box-shadow: 0 0px 0 transparent !important; margin-bottom: -4px; }
    .btn-jogavel:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-primario { background-color: #1cb0f6; color: white; box-shadow: 0 6px 0 #1899d6; }
    .btn-neutro { background-color: #ffffff; color: #4b4b4b; border: 2px solid #e5e7eb; box-shadow: 0 6px 0 #e5e7eb; }
</style>

<div class="tela-app">
    
    <div class="topo-app">
        <div>
            <h5 class="fw-bold mb-0 text-dark" style="letter-spacing: -0.5px;">🎯 Desafio</h5>
        </div>
        @if (questaoAtual != null)
        {
            <span class="badge bg-light text-secondary border rounded-pill px-3 py-2 fw-bold">
                @(questaoAtual.Tipo == "certo_errado" ? "Certo/Errado" : "Múltipla Escolha")
            </span>
        }
    </div>

    @if (carregando)
    {
        <div class="d-flex justify-content-center align-items-center flex-grow-1">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (questaoAtual == null)
    {
        <div class="d-flex flex-column justify-content-center align-items-center flex-grow-1 text-center p-4">
            <span class="fs-1 d-block mb-3">📭</span>
            <h5 class="fw-bold text-dark">Conhecimento não encontrado</h5>
            <button class="btn btn-primary rounded-pill mt-3 px-4" @onclick="VoltarParaLista">Voltar</button>
        </div>
    }
    else
    {
        <div class="area-split">
            
            <div class="area-enunciado">
                <span class="text-uppercase fw-bold mb-2 d-block" style="font-size: 0.75rem; color: #afafaf; letter-spacing: 1px;">Texto Base / Situação-Problema</span>
                <p class="fs-6 fw-bold text-dark mb-0" style="white-space: pre-line; line-height: 1.6;">
                    @questaoAtual.Enunciado
                </p>
            </div>

            <div class="area-alternativas">
                <div class="d-flex flex-column">
                    @foreach (var (alt, i) in questaoAtual.Alternativas.Select((value, index) => (value, index)))
                    {
                        var letra = questaoAtual.Tipo == "certo_errado" ? (i == 0 ? "C" : "E") : ((char)('A' + i)).ToString();
                        var estadoCss = ObterClasseAlternativa(alt.Id);

                        <div class="alt-opcao @estadoCss" @onclick="() => SelecionarAlternativa(alt.Id)">
                            <div class="num-bolinha">@letra</div>
                            <div class="texto-alternativa">@alt.Texto</div>
                            
                            @if (respondido && alt.IsCorreta)
                            {
                                <span class="fs-5 text-success fw-bold ms-auto">✓</span>
                            }
                            else if (respondido && alt.Id == alternativaSelecionadaId && !alt.IsCorreta)
                            {
                                <span class="fs-5 text-danger fw-bold ms-auto">×</span>
                            }
                        </div>
                    }
                </div>
            </div>
            
        </div>

        <div class="barra-acao-inferior">
            <div class="barra-acao-inner">
                @if (!respondido)
                {
                    <button class="btn-jogavel btn-primario" 
                            disabled="@(string.IsNullOrEmpty(alternativaSelecionadaId))" 
                            @onclick="ConfirmarResposta">
                        Confirmar Resposta
                    </button>
                }
                else
                {
                    <button class="btn-jogavel btn-neutro" @onclick="VoltarParaLista">
                        Voltar para o Mural
                    </button>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string QuestaoId { get; set; }

    private Questao? questaoAtual;
    private string? alternativaSelecionadaId;
    private bool respondido = false;
    private bool carregando = true;

    private readonly string idTrabalhador = "e414792c-8943-491d-8bb5-947fe554f25d";

    protected override async Task OnInitializedAsync()
    {
        await CarregarQuestao();
    }

    private async Task CarregarQuestao()
    {
        carregando = true;
        try
        {
            // Busca e desempacota com o transportador robusto
            var jsonBusca = await Http.GetStringAsync("/api/questoes");
            var todasQuestoes = Newtonsoft.Json.JsonConvert.DeserializeObject<List<Questao>>(jsonBusca) ?? new();
            questaoAtual = todasQuestoes.FirstOrDefault(q => q.Id == QuestaoId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar a questão: {ex.Message}");
        }
        finally
        {
            carregando = false;
        }
    }

    private void SelecionarAlternativa(string id)
    {
        if (respondido) return;
        alternativaSelecionadaId = id;
    }

    private string ObterClasseAlternativa(string altId)
    {
        if (!respondido)
        {
            return alternativaSelecionadaId == altId ? "selecionada" : "";
        }

        var alt = questaoAtual!.Alternativas.First(a => a.Id == altId);
        if (alt.IsCorreta) return "correta-revelada desativada";
        if (alternativaSelecionadaId == altId && !alt.IsCorreta) return "errada-revelada desativada";
        return "desativada opacity-50";
    }

    private async Task ConfirmarResposta()
    {
        if (string.IsNullOrEmpty(alternativaSelecionadaId) || questaoAtual == null) return;

        var altEscolhida = questaoAtual.Alternativas.First(a => a.Id == alternativaSelecionadaId);
        respondido = true;

        var novaResposta = new Resposta
        {
            RespondidoPor = idTrabalhador,
            QuestaoId = questaoAtual.Id,
            Correta = altEscolhida.IsCorreta
        };

        try
        {
            // Empacota e envia via API com o formato correto
            var jsonEnvio = Newtonsoft.Json.JsonConvert.SerializeObject(novaResposta);
            await Http.PostAsync("/api/respostas", new StringContent(jsonEnvio, System.Text.Encoding.UTF8, "application/json"));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao registrar no banco: {ex.Message}");
        }
    }

    private void VoltarParaLista()
    {
        NavManager.NavigateTo("/resolver");
    }
}