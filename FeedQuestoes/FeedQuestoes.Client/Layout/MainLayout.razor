@inherits LayoutComponentBase
@inject NavigationManager NavManager

<div class="page">
    <main>
        @Body
    </main>
</div>

<nav class="mobile-bottom-nav">
    <div class="nav-item" @onclick='() => Navegar("/")'>
        <span class="nav-icon">🏠</span>
        <span class="nav-text">Início</span>
    </div>
    <div class="nav-item" @onclick='() => Navegar("/feed")'>
        <span class="nav-icon">🌍</span>
        <span class="nav-text">Mural</span>
    </div>
    <div class="nav-item" @onclick='() => Navegar("/nova-questao")'>
        <span class="nav-icon">🛠️</span>
        <span class="nav-text">Forjar</span>
    </div>
    <div class="nav-item" @onclick='() => Navegar("/desempenho")'>
        <span class="nav-icon">📈</span>
        <span class="nav-text">Perfil</span>
    </div>
</nav>

<style>
    /* Garante que o conteúdo final das páginas não fique escondido atrás da barra inferior */
    main {
        padding-bottom: 80px;
    }

    .mobile-bottom-nav {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: 70px;
        background: #ffffff;
        border-top: 2px solid #e5e7eb;
        display: flex;
        justify-content: space-around;
        align-items: center;
        /* O z-index 999 garante que ela fique por cima de quase tudo,
               EXCETO do nosso Feed Contínuo (TikTok) que usa z-index 2000 */
        z-index: 999;
        /* Uma proteção vital para iPhones modernos (a barra inferior de gestos) */
        padding-bottom: env(safe-area-inset-bottom);
    }

    .nav-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #afafaf;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.1s ease-in-out;
        width: 100%;
        height: 100%;
        user-select: none;
    }

        .nav-item:active {
            color: #1cb0f6;
            transform: translateY(2px);
        }

    .nav-icon {
        font-size: 22px;
        margin-bottom: 2px;
    }

    .nav-text {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
</style>

@code {
    private void Navegar(string rota)
    {
        NavManager.NavigateTo(rota);
    }
}