@page "/"
@using System.Linq
@using FeedQuestoes.Client.Modelos
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>Mapa de Conhecimento | Base Coletiva</PageTitle>

<style>
    .home-container { padding-bottom: 100px; background-color: #f7f9fc; min-height: 100vh; font-family: 'Segoe UI', system-ui, sans-serif; }
    .header-secao { padding: 30px 20px; background: #fff; border-bottom: 2px solid #e5e7eb; }
    
    .arvore-container { padding: 25px 15px; }

    /* Estrutura do Nó e da Hierarquia */
    .assunto-nodo { margin-bottom: 10px; }
    
    .card-assunto { 
        background: #ffffff; border: 2px solid #e5e7eb; border-radius: 14px; padding: 12px 16px; 
        cursor: pointer; transition: all 0.1s ease-in-out; box-shadow: 0 4px 0 #e5e7eb;
        display: flex; align-items: center; gap: 12px; position: relative;
    }
    .card-assunto:active { transform: translateY(3px); box-shadow: 0 1px 0 #e5e7eb; }
    .card-assunto:hover { border-color: #1cb0f6; }
    
    .emoji-assunto { font-size: 1.4rem; }
    .nome-assunto { font-weight: 800; color: #4b4b4b; font-size: 0.9rem; line-height: 1.2; }

    /* A linha tracejada que guia a leitura da hierarquia */
    .hierarquia-filhos {
        margin-top: 10px;
        margin-left: 22px;
        padding-left: 18px;
        border-left: 2px dashed #cbd5e1;
        display: flex;
        flex-direction: column;
    }
</style>

<div class="home-container">
    <div class="header-secao">
        <h4 class="fw-black mb-1">Mapa de Operações 🗺️</h4>
        <p class="text-muted fw-bold small mb-0">Cada assunto é um território a ser conquistado.</p>
    </div>

    @if (carregando)
    {
        <div class="text-center p-5 text-muted fw-bold">
            <div class="spinner-border text-primary mb-3"></div>
            <p>Sincronizando meios de produção...</p>
        </div>
    }
    else
    {
        <div class="arvore-container">
            @* Inicializamos a renderização a partir das Raízes (assuntos que não têm pai) *@
            @foreach (var raiz in ObterRaizes())
            {
                @RenderArvore(raiz)
            }
        </div>
    }
</div>

@code {
    private List<Assunto> listaAssuntos = new();
    private List<AssuntoHierarquia> relacoes = new();
    private bool carregando = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var taskAssuntos = Http.GetStringAsync("/api/territorios");
            var taskHierarquia = Http.GetStringAsync("/api/territorios/hierarquia");

            await Task.WhenAll(taskAssuntos, taskHierarquia);

            listaAssuntos = Newtonsoft.Json.JsonConvert.DeserializeObject<List<Assunto>>(await taskAssuntos) ?? new();
            relacoes = Newtonsoft.Json.JsonConvert.DeserializeObject<List<AssuntoHierarquia>>(await taskHierarquia) ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro na sincronização da base: {ex.Message}");
        }
        finally
        {
            carregando = false;
        }
    }

    // ------------------------------------------------------------------------
    // O CORAÇÃO DA RECURSIVIDADE: Um método que gera blocos visuais HTML
    // ------------------------------------------------------------------------
    private RenderFragment RenderArvore(Assunto assunto) => __builder =>
    {
        <div class="assunto-nodo">
            @* O card principal, sempre clicável *@
            <div class="card-assunto" @onclick="() => Explorar(assunto.Id)">
                <span class="emoji-assunto">🎯</span>
                <span class="nome-assunto">@assunto.Nome</span>
            </div>
            
            @* A mágica acontece aqui: procuramos filhos e, se houver, o método chama a si mesmo *@
            @{ var filhos = ObterFilhos(assunto.Id); }
            @if (filhos.Any())
            {
                <div class="hierarquia-filhos">
                    @foreach (var filho in filhos)
                    {
                        @RenderArvore(filho)
                    }
                </div>
            }
        </div>
    };

    // ------------------------------------------------------------------------
    // FILTROS COLETIVOS (LINQ)
    // ------------------------------------------------------------------------
    
    private List<Assunto> ObterRaizes()
    {
        // Uma raiz é qualquer assunto que NUNCA aparece como 'Filho' na tabela de relações
        var idsFilhos = relacoes.Select(r => r.FilhoId).ToHashSet();
        return listaAssuntos.Where(a => !idsFilhos.Contains(a.Id)).ToList();
    }

    private List<Assunto> ObterFilhos(Guid paiId)
    {
        // Extrai os filhos diretos do nó atual
        var idsFilhos = relacoes.Where(r => r.PaiId == paiId).Select(r => r.FilhoId).ToHashSet();
        return listaAssuntos.Where(a => idsFilhos.Contains(a.Id)).ToList();
    }

    private void Explorar(Guid id) => NavManager.NavigateTo($"/territorio/{id}");
}